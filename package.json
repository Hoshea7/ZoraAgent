{
  "name": "zora",
  "version": "0.1.0",
  "description": "Zora 桌面AI伙伴",
  "main": "dist/main/index.js",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:main\" \"bun run dev:renderer\" \"bun run dev:electron\"",
    "dev:main": "bun run esbuild.config.ts --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 file:dist/main/index.js file:dist/main/preload.js && env -u ELECTRON_RUN_AS_NODE -u ELECTRON_FORCE_IS_PACKAGED VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron . --remote-debugging-port=9222",
    "build": "bun run build:main && bun run build:renderer",
    "pack": "bun run build && electron-builder --dir",
    "dist:mac": "bun run build && electron-builder --mac",
    "dist:mac:arm64": "bun run build && electron-builder --mac --arm64",
    "dist:mac:x64": "bun run build && electron-builder --mac --x64",
    "dist:mac:universal": "bun run build && electron-builder --mac --universal",
    "dist:mac:unsigned": "bun run build && electron-builder --mac --config.mac.identity=-",
    "dist:mac:arm64:unsigned": "bun run build && electron-builder --mac --arm64 --config.mac.identity=-",
    "dist:mac:x64:unsigned": "bun run build && electron-builder --mac --x64 --config.mac.identity=-",
    "dist:win": "bun run build && electron-builder --win",
    "dist:linux": "bun run build && electron-builder --linux",
    "build:main": "bun run esbuild.config.ts",
    "build:renderer": "vite build",
    "vendor:bun": "bun run scripts/download-bun.ts",
    "vendor:bun:all": "bun run scripts/download-bun.ts --all",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jotai": "^2.12.5",
    "marked": "^17.0.4",
    "mermaid": "^11.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-toc": "^9.0.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.2",
    "vite": "^7.1.0",
    "wait-on": "^8.0.3"
  }
}
